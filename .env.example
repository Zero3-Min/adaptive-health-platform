# LLM provider（可选：anthropic | ark；不设置则按 key 自动选择，都没有则 mock 模式）
LLM_PROVIDER=

# 方案 A：Anthropic API（Coach / Reflection Agent）
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 方案 B：火山方舟（一把 key 通用；模型填方舟模型 ID 或推理接入点 ep-xxx）
ARK_API_KEY=
ARK_MODEL_COACH=ep-your-coach-endpoint        # 建议对话质量强的模型（如 seed lite）
ARK_MODEL_REFLECTION=ep-your-reflection-endpoint  # 建议结构化/推理强的模型（如 deepseek flash）
ARK_MODEL=                                    # 兜底：未按角色配置时用这个
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# PostgreSQL（需启用 pgvector 扩展）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health_platform
